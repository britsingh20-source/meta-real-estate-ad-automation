# ─────────────────────────────────────────────────────────────
# Meta Real Estate Ad Automation — Environment Variables
# Copy this file to .env for local testing (never commit .env)
# In production: add these as GitHub Actions Secrets
# ─────────────────────────────────────────────────────────────

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_page_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id       # Must start with act_
META_PAGE_ID=your_facebook_page_id
META_LEAD_FORM_ID=your_lead_gen_form_id
META_CAMPAIGN_ID=                                # Auto-detected if left blank
